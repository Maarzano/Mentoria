# ==============================================================================
# FoodeApp — Variáveis de Ambiente (Template)
#
# Copie este arquivo para .env e preencha os valores sensíveis.
#   cp .env.example .env
#
# Este arquivo é versionado pelo Git. NÃO coloque segredos aqui.
#
# FLUXO DE CONFIGURAÇÃO (ver docs/CONFIGURATION.md):
#   .env → proj.ps1 / dotenv.net → $env:* → IOptions<T>
#   Portas: .env → services.json (fallback)
#   Segredos (POSTGRES_PASSWORD, etc.): obrigatórios — erro claro se ausentes
# ==============================================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=pgadmin
POSTGRES_PASSWORD=

# ── Databases (um por microserviço — ADR-002) ────────────────────────────────
POSTGRES_DB_users=foodeapp_users
POSTGRES_DB_CATALOG=foodeapp_catalog
POSTGRES_DB_ESTABLISHMENTS=foodeapp_establishments
POSTGRES_DB_EVENTS=foodeapp_events
POSTGRES_DB_LOCATIONS=foodeapp_locations
POSTGRES_DB_ORDERS=foodeapp_orders
POSTGRES_DB_NOTIFICATIONS=foodeapp_notifications
POSTGRES_DB_PAYMENTS=foodeapp_payments

# ── RabbitMQ (ADR-006) ───────────────────────────────────────────────────────
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=

# ── Redis (ADR-012) ──────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Observabilidade (ADR-018) ────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# ── Keycloak (ADR-026 — quando ativado) ──────────────────────────────────────
KEYCLOAK_REALM_URL=http://localhost:8180/realms/foodeapp
KEYCLOAK_CLIENT_ID=foodeapp-api

# ── Portas dos Serviços ──────────────────────────────────────────────────────
SVC_users_PORT=8080
SVC_CATALOG_PORT=8081
SVC_ESTABLISHMENTS_PORT=8082
SVC_EVENTS_PORT=8083
SVC_LOCATION_PORT=8084
SVC_ORDERS_PORT=8085
SVC_NOTIFICATIONS_PORT=8086
SVC_PAYMENTS_PORT=8087
BFF_WEB_PORT=8090
BFF_MOBILE_PORT=8091
WEB_PORT=3001
MOBILE_PORT=19000

# ── Portas da Infraestrutura ─────────────────────────────────────────────────
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090
TEMPO_PORT=3200
LOKI_PORT=3100
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
