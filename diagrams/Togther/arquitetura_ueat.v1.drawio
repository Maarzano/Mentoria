                <mxCell id="c17DG_hq72BnOwkdbsdk-120" style="edgeStyle=none;html=1;entryX=0.75;entryY=0;entryDx=0;entryDy=0;fillColor=#fa6800;strokeColor=#C73500;" edge="1" parent="1" source="c17DG_hq72BnOwkdbsdk-119" target="ZMD-k1KkdO0GaXOnLm97-85">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="c17DG_hq72BnOwkdbsdk-119" value="&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;font-size: 11px;&quot;&gt;Pode fazer outros tipos de caching, para edge caching&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fillWeight=4;hachureGap=8;hachureAngle=45;fillColor=none;strokeColor=#C73500;shadow=0;glass=0;fontColor=#000000;sketch=1;curveFitting=1;jiggle=2;fillStyle=hachure;" vertex="1" parent="1">
                    <mxGeometry x="-10" y="1970" width="160" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="c17DG_hq72BnOwkdbsdk-124" style="edgeStyle=none;html=1;entryX=0.562;entryY=0.007;entryDx=0;entryDy=0;fillColor=#fa6800;strokeColor=#C73500;entryPerimeter=0;" edge="1" parent="1" source="c17DG_hq72BnOwkdbsdk-123" target="7">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="1170" y="1840" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="c17DG_hq72BnOwkdbsdk-123" value="&lt;span style=&quot;text-wrap-mode: nowrap;&quot;&gt;Ele pode ter plugins e ligado ao redis, para ter uma memória básica&lt;/span&gt;&lt;div&gt;&lt;span style=&quot;text-wrap-mode: nowrap;&quot;&gt;E fazer Rate Limiting distribuído ou outras coisas, como cache&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fillWeight=4;hachureGap=8;hachureAngle=45;fillColor=none;strokeColor=#C73500;shadow=0;glass=0;fontColor=#000000;sketch=1;curveFitting=1;jiggle=2;fillStyle=hachure;align=left;verticalAlign=middle;spacingLeft=6;" vertex="1" parent="1">
                    <mxGeometry x="1070" y="1620" width="380" height="57.5" as="geometry"/>
                </mxCell>
                <mxCell id="c17DG_hq72BnOwkdbsdk-129" value="External LB" style="whiteSpace=wrap;html=1;" vertex="1" parent="1">
                    <mxGeometry x="455" y="2160" width="80" height="470" as="geometry"/>
                </mxCell>
                <mxCell id="c17DG_hq72BnOwkdbsdk-131" style="edgeStyle=none;html=1;entryX=0.25;entryY=0;entryDx=0;entryDy=0;fillColor=#fa6800;strokeColor=#C73500;" edge="1" parent="1" source="c17DG_hq72BnOwkdbsdk-130" target="c17DG_hq72BnOwkdbsdk-129">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="c17DG_hq72BnOwkdbsdk-130" value="&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;font-size: 11px;&quot;&gt;Pode fazer descriptação https&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;font-size: 11px;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;color: rgb(192, 192, 192); font-size: 11px;&quot;&gt;Vai fazer o balanceamento para as instancias do kong&lt;/span&gt;&lt;span style=&quot;font-size: 11px;&quot;&gt;&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fillWeight=4;hachureGap=8;hachureAngle=45;fillColor=none;strokeColor=#C73500;shadow=0;glass=0;fontColor=#000000;sketch=1;curveFitting=1;jiggle=2;fillStyle=hachure;" vertex="1" parent="1">
                    <mxGeometry x="390" y="2000" width="170" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="c17DG_hq72BnOwkdbsdk-133" value="&lt;font style=&quot;color: rgb(255, 255, 255);&quot;&gt;API deve ter health checks de 3 níveis para linkar ao Kong e ao kubernets para saber se vai matar a instância ou o que&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fillWeight=4;hachureGap=8;hachureAngle=45;fillColor=none;strokeColor=#005700;shadow=0;glass=0;fontColor=#ffffff;sketch=1;curveFitting=1;jiggle=2;fillStyle=hachure;" vertex="1" parent="1">
                    <mxGeometry x="-565" y="310" width="200" height="132.5" as="geometry"/>
                </mxCell>
                <mxCell id="c17DG_hq72BnOwkdbsdk-134" value="&lt;font style=&quot;color: rgb(255, 255, 255);&quot;&gt;Quero utilizar feature flags, pelo menos em algumas coisas para testar como se faz pode ser em features novas... podemos usar Redis para guardar ela, mas aí precisaríamos criar o front para mudar, ou usar SaaS disso. Podemos usar o Kong para canary release. Mas precisamos tomar cuidado com feature flags viverem tempo demais... precisamos excluir elas depois de validar.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fillWeight=4;hachureGap=8;hachureAngle=45;fillColor=none;strokeColor=#005700;shadow=0;glass=0;fontColor=#ffffff;sketch=1;curveFitting=1;jiggle=2;fillStyle=hachure;" vertex="1" parent="1">
                    <mxGeometry x="-587.5" y="1120" width="212.5" height="192.5" as="geometry"/>
                </mxCell>
                <mxCell id="c17DG_hq72BnOwkdbsdk-135" value="&lt;font style=&quot;color: rgb(255, 255, 255);&quot;&gt;usaremos IAC para facilitar a replicação da nuvem&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fillWeight=4;hachureGap=8;hachureAngle=45;fillColor=none;strokeColor=#005700;shadow=0;glass=0;fontColor=#ffffff;sketch=1;curveFitting=1;jiggle=2;fillStyle=hachure;" vertex="1" parent="1">
                    <mxGeometry x="-325" y="810" width="190" height="72.5" as="geometry"/>
                </mxCell>
                <mxCell id="c17DG_hq72BnOwkdbsdk-137" value="&lt;font style=&quot;color: rgb(255, 255, 255);&quot;&gt;backplane&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fillWeight=4;hachureGap=8;hachureAngle=45;fillColor=none;strokeColor=#005700;shadow=0;glass=0;fontColor=#ffffff;sketch=1;curveFitting=1;jiggle=2;fillStyle=hachure;" vertex="1" parent="1">
                    <mxGeometry x="-970" y="169.5" width="200" height="132.5" as="geometry"/>
                </mxCell>
                <mxCell id="c17DG_hq72BnOwkdbsdk-138" value="&lt;font style=&quot;color: rgb(255, 255, 255);&quot;&gt;podemos usar i18n para diferenciamento (nunca mexi)&lt;/font&gt;&lt;div&gt;&lt;font style=&quot;color: rgb(255, 255, 255);&quot;&gt;ou podemos deixar para depois para diminuir complexidade&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fillWeight=4;hachureGap=8;hachureAngle=45;fillColor=none;strokeColor=#005700;shadow=0;glass=0;fontColor=#ffffff;sketch=1;curveFitting=1;jiggle=2;fillStyle=hachure;" vertex="1" parent="1">
                    <mxGeometry x="-335" y="670" width="200" height="132.5" as="geometry"/>
                </mxCell>
                <mxCell id="c17DG_hq72BnOwkdbsdk-139" value="&lt;font style=&quot;color: rgb(255, 255, 255);&quot;&gt;Cada camada se precisar terá&amp;nbsp;&lt;span style=&quot;color: rgb(255, 255, 255);&quot;&gt;Retry, Circuit breaker, fallback&lt;/span&gt;, com lógica exponencial e valor de tempo a leatorío dado um tempo...&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fillWeight=4;hachureGap=8;hachureAngle=45;fillColor=none;strokeColor=#005700;shadow=0;glass=0;fontColor=#ffffff;sketch=1;curveFitting=1;jiggle=2;fillStyle=hachure;" vertex="1" parent="1">
                    <mxGeometry x="-340" y="890" width="210" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="c17DG_hq72BnOwkdbsdk-143" value="" style="verticalLabelPosition=bottom;html=1;verticalAlign=top;align=center;strokeColor=none;fillColor=#00BEF2;shape=mxgraph.azure.queue_generic;pointerEvents=1;" vertex="1" parent="1">
                    <mxGeometry x="-850" y="900" width="133.34" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="zdCqv2ozAaiuYf06vWsH-85" value="&lt;font style=&quot;color: rgb(255, 255, 255);&quot;&gt;usaremos cache em várias camadas, mas com cuidado para não virar um cache inifinito e gigantes, precisamos separar po importância volume de mudança e coisa pesadas e escolher a forma de invalidar o cache&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fillWeight=4;hachureGap=8;hachureAngle=45;fillColor=none;strokeColor=#005700;shadow=0;glass=0;fontColor=#ffffff;sketch=1;curveFitting=1;jiggle=2;fillStyle=hachure;" vertex="1" parent="1">
                    <mxGeometry x="-575" y="969.5" width="200" height="132.5" as="geometry"/>
                </mxCell>
                <mxCell id="zdCqv2ozAaiuYf06vWsH-86" value="&lt;font style=&quot;color: rgb(255, 255, 255);&quot;&gt;precisamos do padrão SAGA para por exemplo devolver dinheiro caso algo aconteça após a cobrança ou outra coisa.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fillWeight=4;hachureGap=8;hachureAngle=45;fillColor=none;strokeColor=#005700;shadow=0;glass=0;fontColor=#ffffff;sketch=1;curveFitting=1;jiggle=2;fillStyle=hachure;" vertex="1" parent="1">
                    <mxGeometry x="-575" y="862" width="220" height="82.5" as="geometry"/>
                </mxCell>
                <mxCell id="zdCqv2ozAaiuYf06vWsH-89" value="&lt;font style=&quot;color: rgb(255, 255, 255);&quot;&gt;Resolveremos o problema idepotencia, usando chave que o cliente vai mandar, TTL, assim a API vai saber se processou algo em tais minutos.&lt;br&gt;Ah e um redis para guardar rápido e compartilhar entre instâncias da API, e depois no Postgres para auditoria&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fillWeight=4;hachureGap=8;hachureAngle=45;fillColor=none;strokeColor=#005700;shadow=0;glass=0;fontColor=#ffffff;sketch=1;curveFitting=1;jiggle=2;fillStyle=hachure;" vertex="1" parent="1">
                    <mxGeometry x="-595" y="712" width="250" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="zdCqv2ozAaiuYf06vWsH-90" value="&lt;font style=&quot;color: rgb(255, 255, 255);&quot;&gt;Podemos usar ElastichSearch para fazer pesquisa, pois a função de olhar restaurantes é uma das mais acessadas, ou até mesmo lugares&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fillWeight=4;hachureGap=8;hachureAngle=45;fillColor=none;strokeColor=#005700;shadow=0;glass=0;fontColor=#ffffff;sketch=1;curveFitting=1;jiggle=2;fillStyle=hachure;" vertex="1" parent="1">
                    <mxGeometry x="-335" y="169.5" width="200" height="132.5" as="geometry"/>
                </mxCell>
                <mxCell id="zdCqv2ozAaiuYf06vWsH-92" value="&lt;font style=&quot;color: rgb(255, 255, 255);&quot;&gt;Vamos usar CQRS para separar querya de leitura e escrita.&lt;br&gt;&lt;br&gt;Mas inicialmente não iremos separar banco de dados de leitura e escrita&lt;br&gt;&lt;br&gt;podemos resolver o problema de lag de replicação usando fake front, dizendo que deu certo antes mesmo de saber se deu, caso dê errado, aí a gente avisa&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fillWeight=4;hachureGap=8;hachureAngle=45;fillColor=none;strokeColor=#005700;shadow=0;glass=0;fontColor=#ffffff;sketch=1;curveFitting=1;jiggle=2;fillStyle=hachure;" vertex="1" parent="1">
                    <mxGeometry x="-350" y="460" width="220" height="192.5" as="geometry"/>
                </mxCell>
                <mxCell id="zdCqv2ozAaiuYf06vWsH-93" value="&lt;font style=&quot;color: rgb(255, 255, 255);&quot;&gt;podemos usar server driven UI, para atualizar as coisas sem precisar atualizar o front. Nunca mexi e parece legal, mas não vamos colocar em tudo, talvez em features novas...&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fillWeight=4;hachureGap=8;hachureAngle=45;fillColor=none;strokeColor=#005700;shadow=0;glass=0;fontColor=#ffffff;sketch=1;curveFitting=1;jiggle=2;fillStyle=hachure;" vertex="1" parent="1">
                    <mxGeometry x="-345" y="338" width="210" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="zdCqv2ozAaiuYf06vWsH-94" value="&lt;font style=&quot;color: rgb(255, 255, 255);&quot;&gt;podemos ter WebSocket em conversas, ou então em status de pedidos&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fillWeight=4;hachureGap=8;hachureAngle=45;fillColor=none;strokeColor=#005700;shadow=0;glass=0;fontColor=#ffffff;sketch=1;curveFitting=1;jiggle=2;fillStyle=hachure;" vertex="1" parent="1">
                    <mxGeometry x="-575" y="632" width="200" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="zdCqv2ozAaiuYf06vWsH-95" value="&lt;font style=&quot;color: rgb(255, 255, 255);&quot;&gt;Teremos elasticidade com kubernetes, onde ele vê como as coisas estão se comportando e se precisar cria instâncias, se não preicsa mais mata.&lt;br&gt;&lt;br&gt;Conversaremos com provedores, para subir outras máquinas caso precisemos tbm,&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fillWeight=4;hachureGap=8;hachureAngle=45;fillColor=none;strokeColor=#005700;shadow=0;glass=0;fontColor=#ffffff;sketch=1;curveFitting=1;jiggle=2;fillStyle=hachure;" vertex="1" parent="1">
                    <mxGeometry x="-565" y="460" width="200" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="zdCqv2ozAaiuYf06vWsH-96" value="&lt;font style=&quot;color: rgb(255, 255, 255);&quot;&gt;Conversas entre môdulos vai ser via eventos&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fillWeight=4;hachureGap=8;hachureAngle=45;fillColor=none;strokeColor=#005700;shadow=0;glass=0;fontColor=#ffffff;sketch=1;curveFitting=1;jiggle=2;fillStyle=hachure;" vertex="1" parent="1">
                    <mxGeometry x="-335" y="100" width="200" height="49.5" as="geometry"/>
                </mxCell>
                <mxCell id="zdCqv2ozAaiuYf06vWsH-98" value="&lt;font style=&quot;color: rgb(255, 255, 255);&quot;&gt;Podemos usar uma tabela Outbox para que ao escrever em diferente modulos podemos primeiro escrever na Outbox, e a fila tenta mandar, caso falhe, ela vai tentar de novo depois pq conitnua no outbox lá com processed = null.&lt;/font&gt;&lt;div&gt;&lt;font style=&quot;color: rgb(255, 255, 255);&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: rgb(255, 255, 255);&quot;&gt;mas vamos precisar de workers de limpeza para limpar dados antigos de vez em quando.&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fillWeight=4;hachureGap=8;hachureAngle=45;fillColor=none;strokeColor=#005700;shadow=0;glass=0;fontColor=#ffffff;sketch=1;curveFitting=1;jiggle=2;fillStyle=hachure;" vertex="1" parent="1">
                    <mxGeometry x="-340" y="-100" width="215" height="189.5" as="geometry"/>
                </mxCell>
                <mxCell id="zdCqv2ozAaiuYf06vWsH-100" value="&lt;font color=&quot;#ffffff&quot;&gt;tentar automatiza bastante, para diminuir a necessidade de mãos humanas para aquilo, como CI/CD e outras coisas&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fillWeight=4;hachureGap=8;hachureAngle=45;fillColor=none;strokeColor=#005700;shadow=0;glass=0;fontColor=#ffffff;sketch=1;curveFitting=1;jiggle=2;fillStyle=hachure;" vertex="1" parent="1">
                    <mxGeometry x="-565" y="-120" width="200" height="132.5" as="geometry"/>
                </mxCell>
                <mxCell id="zdCqv2ozAaiuYf06vWsH-101" value="&lt;font color=&quot;#ffffff&quot;&gt;Devemos fazer partição das tabelas mais usadas e mais acessadas para não termos problema com quantidade de coisas... Agora a forma e qual indice usar para particionar podemos olhar, talvez data...&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fillWeight=4;hachureGap=8;hachureAngle=45;fillColor=none;strokeColor=#005700;shadow=0;glass=0;fontColor=#ffffff;sketch=1;curveFitting=1;jiggle=2;fillStyle=hachure;" vertex="1" parent="1">
                    <mxGeometry x="-565" y="-270" width="200" height="132.5" as="geometry"/>
                </mxCell>
                <mxCell id="zdCqv2ozAaiuYf06vWsH-102" value="&lt;font color=&quot;#ffffff&quot;&gt;vamos começar apenas 1 instância de cada banco, mas podemos depois evoluir para multiplas instâncias de leitura... Depois talvez Sharding por área ou por outro&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fillWeight=4;hachureGap=8;hachureAngle=45;fillColor=none;strokeColor=#005700;shadow=0;glass=0;fontColor=#ffffff;sketch=1;curveFitting=1;jiggle=2;fillStyle=hachure;" vertex="1" parent="1">
                    <mxGeometry x="-340" y="-210" width="200" height="102.5" as="geometry"/>
                </mxCell>
                <mxCell id="ZHVIvnVoHwWRqAKxdAmr-13" value="Untitled Layer" parent="0"/>
