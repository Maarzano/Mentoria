                <mxCell id="48" value="Untitled Layer" parent="0"/>
                <mxCell id="62" value="usar arquiteturas por níveis de criticidade&lt;div&gt;1. DDD/Hexa/Clean&lt;/div&gt;&lt;div&gt;2.Layered Architecture (Service/Controller/Repository)&lt;/div&gt;&lt;div&gt;3.Simples sla, MVC&amp;nbsp;&amp;nbsp;&lt;/div&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="48" vertex="1">
                    <mxGeometry x="-1000" y="391.25" width="310" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="65" value="GraphQL para facilitar front?" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="48" vertex="1">
