<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <!-- Driver nativo PostgreSQL — usado pelo read side (SQL raw → DTO) -->
    <PackageReference Include="Npgsql" Version="10.0.2" />
    <!-- EF Core + provider Npgsql — usado pelo write side (Commands) -->
    <PackageReference Include="Npgsql.EntityFrameworkCore.PostgreSQL" Version="9.0.4" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="10.0.0" />
    <!-- Dapper para read side — mapeia SQL → DTO sem ORM (ADR-004/005) -->
    <PackageReference Include="Dapper" Version="2.1.66" />
    <!-- FluentMigrator para migrações de banco versionadas -->
    <PackageReference Include="FluentMigrator" Version="6.2.0" />
    <PackageReference Include="FluentMigrator.Runner" Version="6.2.0" />
    <PackageReference Include="FluentMigrator.Runner.Postgres" Version="6.2.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\FoodeApp.SvcUsers.Domain\FoodeApp.SvcUsers.Domain.csproj" />
    <!-- IUserReadRepository retorna Application DTOs â€” dependÃªncia permitida (Adapters â†’ Application) -->
    <ProjectReference Include="..\FoodeApp.SvcUsers.Application\FoodeApp.SvcUsers.Application.csproj" />
    <ProjectReference Include="..\..\..\..\shared\kernel-dotnet\src\FoodeApp.Kernel\FoodeApp.Kernel.csproj" />
  </ItemGroup>

</Project>
