      "link": null,
      "locked": false,
      "text": "Ao entrar no app a\npessoa pode ver\nrestaurantes e adicionar\na sacola itens.\n\nPorém só poderá finalizar\na compra se estiver\nlogado.",
      "fontSize": 53.65374230478451,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "hcSvNSxuHt6PZxY3Q3qmG",
      "originalText": "Ao entrar no app a pessoa pode ver restaurantes e adicionar a sacola itens.\n\nPorém só poderá finalizar a compra se estiver logado.",
      "autoResize": true,
      "lineHeight": 1.25
    },
